{
  "name": "@talchain/schemas",
  "version": "0.22.0",
  "description": "Shared TypeScript schemas and runtime validation for Olumi services",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./boundary": {
      "import": "./dist/boundary/index.js",
      "types": "./dist/boundary/index.d.ts"
    },
    "./orchestrator": {
      "import": "./dist/orchestrator/index.js",
      "types": "./dist/orchestrator/index.d.ts"
    },
    "./fixtures": {
      "import": "./dist/fixtures/index.js",
      "types": "./dist/fixtures/index.d.ts"
    },
    "./json-schema/*.json": "./json-schema/*.json"
  },
  "files": [
    "dist",
    "json-schema"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "generate:json-schema": "npm run build && node scripts/generate-json-schema.mjs",
    "prepublishOnly": "npm run lint && npm run build && npm run test"
  },
  "keywords": [
    "olumi",
    "schemas",
    "validation",
    "zod"
  ],
  "author": "Olumi",
  "license": "UNLICENSED",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Talchain/olumi-schemas.git"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ajv": "^8.20.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
